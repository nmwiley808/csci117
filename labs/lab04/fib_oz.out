[local ["Fib","X","Result"] [Fib = proc {$ N X} [local ["EXU1"] [local ["EXU2","EXU3"] [EXU2 = N,EXU3 = 0,"Eq" "EXU2" "EXU3" "EXU1"],if EXU1 then [skip/st,X = 0] else [local ["EXU2"] [local ["EXU3","EXU4"] [EXU3 = N,EXU4 = 1,"Eq" "EXU3" "EXU4" "EXU2"],if EXU2 then [X = 1] else [local ["A","B","R1","R2"] [local ["EXU2","EXU3","EXU4"] [EXU2 = N,EXU3 = 1,EXU4 = A,"IntMinus" "EXU2" "EXU3" "EXU4"],local ["EXU2","EXU3","EXU4"] [EXU2 = N,EXU3 = 2,EXU4 = B,"IntMinus" "EXU2" "EXU3" "EXU4"],local ["EXU2","EXU3"] [EXU2 = A,EXU3 = R1,"Fib" "EXU2" "EXU3"],local ["EXU2","EXU3"] [EXU2 = B,EXU3 = R2,"Fib" "EXU2" "EXU3"],local ["EXU2","EXU3","EXU4"] [EXU2 = R1,EXU3 = R2,EXU4 = X,"IntPlus" "EXU2" "EXU3" "EXU4"]]]]]]],X = 4,local ["EXU1","EXU2"] [EXU1 = X,EXU2 = Result,"Fib" "EXU1" "EXU2"],skip/BResult]]